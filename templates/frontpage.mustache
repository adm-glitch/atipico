{{!
    @template theme_atipico/frontpage

    Atipico Theme — Frontpage layout

    Context variables required for this template:
    * sitename - The name of the site
    * output - The core renderer for the page
    * bodyattributes - attributes for the body tag as a string of html attributes
    * sidepreblocks - HTML for the blocks
    * hasblocks - true if there are blocks on this page
    * regionmainsettingsmenu - HTML for the region main settings menu
    * hasregionmainsettingsmenu - There is a region main settings menu on this page.
    * slides - Array of slider data (see main_slider partial)
    * hasmultipleslides - true when more than one slide is configured
    * catwidget - true to render the categories section
    * promoboxwidget - true to render the promo box section
    * featuredcourseswidget - true to render the featured courses section

    Example context (json):
    {
        "sitename": "DanKa Academy",
        "bodyattributes": "",
        "hasmultipleslides": false,
        "catwidget": true,
        "promoboxwidget": true,
        "featuredcourseswidget": true
    }
}}
{{> theme_boost/head }}

<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
<div id="page-wrapper" class="d-print-block">

    {{{ output.standard_top_of_body_html }}}

    {{> theme_boost/navbar }}
    <div id="page" data-region="mainpage" data-usertour="scroller" class="homepage drag-container">
        <div id="topofscroll" class="main-inner">
            <div id="page-content" class="d-print-block">
                <div id="region-main-box">
                    {{#hasregionmainsettingsmenu}}
                    <div id="region-main-settings-menu" class="d-print-none">
                        <div> {{{ regionmainsettingsmenu }}} </div>
                    </div>
                    {{/hasregionmainsettingsmenu}}
                    <section id="region-main" aria-label="{{#str}}content{{/str}}">
                        {{#hasregionmainsettingsmenu}}
                            <div class="region_main_settings_menu_proxy"></div>
                        {{/hasregionmainsettingsmenu}}
                        {{{ output.course_content_header }}}
                        {{#headercontent}}
                            {{> core/activity_header }}
                        {{/headercontent}}

                        <section class="at-section at-section--hero">
                            {{> theme_atipico/partials/main_slider }}
                        </section>

                        <div class="top-block-region container d-print-none" aria-label="{{#str}}blocks{{/str}}">
                            {{{ addtopblock }}}
                            {{{ topblock }}}
                        </div>

                        {{#catwidget}}
                        <section class="at-section at-section--categories">
                            {{> theme_atipico/partials/widget_course_categories}}
                        </section>
                        {{/catwidget}}

                        {{#promoboxwidget}}
                        <section class="at-section at-section--promo">
                            {{> theme_atipico/partials/widget_promobox}}
                        </section>
                        {{/promoboxwidget}}

                        {{#featuredcourseswidget}}
                        <section class="at-section at-section--courses">
                            {{> theme_atipico/partials/widget_featured_courses}}
                        </section>
                        {{/featuredcourseswidget}}

                        {{!
                            Moodle requires output.main_content to be called on every layout.
                            Rendered but hidden — the course list is suppressed visually.
                        }}
                        <div class="d-none" aria-hidden="true">
                            {{{ output.main_content }}}
                        </div>
                        <div class="container">
                            {{{ output.activity_navigation }}}
                            {{{ output.course_content_footer }}}
                        </div>
                    </section>
                </div>
            </div>
        </div>
        {{> theme_atipico/partials/footer }}
    </div>
    {{{ output.standard_after_main_region_html }}}
</div>

</body>
</html>
{{#js}}
M.util.js_pending('theme_boost/loader');
require(['theme_boost/loader', 'theme_boost/drawer'], function(Loader, Drawer) {
    Drawer.init();
    M.util.js_complete('theme_boost/loader');
});
{{/js}}

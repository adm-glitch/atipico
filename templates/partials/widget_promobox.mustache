{{!
    @template theme_atipico/partials/widget_promobox

    Atipico Theme — Full-bleed promo / CTA split-screen widget.

    Example context (json):
    {
        "promoboxtitle": "Torne-se um profissional de eventos",
        "promoboxtext": "<p>Formação reconhecida para staff de eventos profissionais.</p>",
        "promoboxurl": "https://example.pt/login/signup.php",
        "promoboxbutton": "Inscreva-se agora",
        "promoboximage": "https://placehold.co/960x600"
    }
}}
<div class="at-promo">
    <div class="at-promo__left">
        <div class="at-promo__inner">
            <h3>{{promoboxtitle}}</h3>
            <div>{{{promoboxtext}}}</div>
            <a class="btn btn-primary btn-lg" role="button" href="{{{promoboxurl}}}">
                {{promoboxbutton}}
            </a>
        </div>
    </div>
    <div class="at-promo__right">
        <img src="{{{promoboximage}}}" alt="" />
    </div>
</div>

{{!
    @template theme_atipico/widget_course_categories

    Atipico Theme — Featured categories widget.

    Example context (json):
    {
        "catwidgetheadingsubtitle": "Explore as nossas áreas de formação",
        "categories": [{
            "name": "Segurança",
            "id": 5,
            "imgurl": "https://placehold.co/600x400",
            "total": 6,
            "coursecountstring": "cursos"
        }],
        "nocategory": false
    }
}}
<div class="container">
    <div class="at-section__header">
        <p class="at-section__eyebrow">
            {{#str}}featuredcategories, theme_atipico{{/str}}
        </p>
        {{#catwidgetheadingsubtitle}}
        <p class="at-section__subtitle">{{catwidgetheadingsubtitle}}</p>
        {{/catwidgetheadingsubtitle}}
    </div>

    <div class="at-cat-grid">
        {{#categories}}
        <a href="course/index.php?categoryid={{id}}" class="at-cat-card">
            <img src="{{imgurl}}" alt="{{name}}">
            <div class="at-cat-card__body">
                <div class="at-cat-card__title">{{name}}</div>
                {{#total}}
                <div class="at-cat-card__count">
                    {{total}} {{coursecountstring}}
                </div>
                {{/total}}
            </div>
        </a>
        {{/categories}}
    </div>

    {{#nocategory}}
    <p class="at-no-results">{{#str}}noresults, theme_atipico{{/str}}</p>
    {{/nocategory}}
</div>

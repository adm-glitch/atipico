{{!
    @template theme_atipico/widget_featured_courses

    Atipico Theme — Featured courses CSS Grid widget (rui-course-card).

    Example context (json):
    {
        "featuredcourses": [{
            "id": 2,
            "fullname": "Segurança em Eventos",
            "category": "Segurança",
            "img": "https://placehold.co/600x340",
            "hidden": "",
            "summary": "Formação essencial para staff de segurança em grandes eventos.",
            "tags": "",
            "startdate": 1735689600,
            "rating": "",
            "completionpercent": 65,
            "completionpercentclass": "rui-progress-65"
        }],
        "nofeaturedcourses": false
    }
}}
<div class="container">
    <div class="at-section__header">
        <p class="at-section__eyebrow">
            {{#str}}featuredcourses, theme_atipico{{/str}}
        </p>
    </div>

    <div class="rui-course-grid">
        {{#featuredcourses}}
        <div class="rui-course-card">

            <div class="rui-course-card__img-wrap">
                <img src="{{img}}" alt="{{fullname}}">
                {{#category}}<span class="rui-course-card__badge">{{category}}</span>{{/category}}
                {{#hidden}}<span class="rui-course-card__badge-soon">{{hidden}}</span>{{/hidden}}
            </div>

            <div class="rui-course-card__body">
                {{#category}}<span class="rui-course-card__cat">{{category}}</span>{{/category}}

                <div class="rui-course-card__title-row">
                    <h5 class="rui-course-card__title">
                        <a href="course/view.php?id={{id}}">{{fullname}}</a>
                    </h5>
                    <span class="rui-progress-ring {{completionpercentclass}}" title="{{completionpercent}}%" aria-label="{{completionpercent}}% {{#str}}complete{{/str}}"></span>
                </div>

                <p class="rui-course-card__summary">
                    {{#shortentext}} 110, {{{summary}}} {{/shortentext}}
                </p>

                {{{tags}}}

                <div class="rui-course-card__meta">
                    {{#startdate}}
                    <span class="rui-course-card__date">
                        <span class="fa fa-calendar" role="img" aria-label="calendar"></span>
                        {{#userdate}} {{startdate}}, {{#str}} strftimedate, core_langconfig {{/str}} {{/userdate}}
                    </span>
                    {{/startdate}}
                    {{#rating}}
                    <span class="rui-course-card__rating">{{{rating}}}</span>
                    {{/rating}}
                </div>
            </div>

        </div>
        {{/featuredcourses}}
    </div>

    {{#nofeaturedcourses}}
    <p class="at-no-results">{{#str}}noresults, theme_atipico{{/str}}</p>
    {{/nofeaturedcourses}}
</div>

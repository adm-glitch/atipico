{{!
    @template theme_atipico/partials/icon_menu

    Quick access icon menu. Rendered inside the drawer-toggles toolbar row on every page
    for logged-in non-guest users. Context is the rui_icon_menu sub-object from drawers.php.

    Example context (json):
    {
        "mycourses_url": "/my/courses.php",
        "messages_url": "/message/index.php",
        "notifications_url": "/message/output/popup/notifications.php",
        "profile_url": "/user/profile.php?id=2",
        "settings_url": "/user/preferences.php",
        "editmode_url": "/course/view.php?id=1&edit=on&sesskey=...",
        "isediting": false,
        "caneditpage": true,
        "editmode_tooltip": "Turn editing on"
    }
}}
<nav class="rui-icon-menu d-print-none" aria-label="Quick access">

    <a href="{{mycourses_url}}"
       class="rui-icon-menu__item"
       data-tooltip="{{tooltip_mycourses}}"
       aria-label="{{tooltip_mycourses}}">
        <i class="fa-solid fa-table-cells" aria-hidden="true"></i>
    </a>

    <a href="{{messages_url}}"
       class="rui-icon-menu__item"
       data-tooltip="{{tooltip_messages}}"
       aria-label="{{tooltip_messages}}">
        <i class="fa-solid fa-message" aria-hidden="true"></i>
    </a>

    <a href="{{notifications_url}}"
       class="rui-icon-menu__item"
       data-tooltip="{{tooltip_notifications}}"
       aria-label="{{tooltip_notifications}}">
        <i class="fa-solid fa-bell" aria-hidden="true"></i>
    </a>

    <a href="{{settings_url}}"
       class="rui-icon-menu__item"
       data-tooltip="{{tooltip_settings}}"
       aria-label="{{tooltip_settings}}">
        <i class="fa-solid fa-gear" aria-hidden="true"></i>
    </a>

    <a href="{{profile_url}}"
       class="rui-icon-menu__item"
       data-tooltip="{{tooltip_profile}}"
       aria-label="{{tooltip_profile}}">
        <i class="fa-solid fa-circle-user" aria-hidden="true"></i>
    </a>

    {{#caneditpage}}
    <a href="{{editmode_url}}"
       class="rui-icon-menu__item rui-icon-menu__editmode{{#isediting}} is-active{{/isediting}}"
       data-tooltip="{{editmode_tooltip}}"
       aria-label="{{editmode_tooltip}}">
        <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
    </a>
    {{/caneditpage}}

</nav>

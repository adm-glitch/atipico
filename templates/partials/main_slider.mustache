{{!
    @template theme_atipico/partials/main_slider

    Atipico Theme — Hero Carousel (Bootstrap 5 syntax)

    Context variables required for this template:
    * slides[]        - array of slide objects
    *   .index        - 0-based slide index
    *   .active       - boolean, true for first slide
    *   .sliderimage  - background image URL
    *   .herotitle    - main headline text
    *   .slidermotto  - subtitle / tagline text
    *   .sliderlink   - CTA button URL (optional)
    *   .sliderbutton - CTA button label text
    * hasmultipleslides - boolean, true when slidestotal > 1

    Example context (json):
    {
        "hasmultipleslides": false,
        "slides": [{
            "index": 0,
            "active": true,
            "sliderimage": "https://placehold.co/1920x860",
            "herotitle": "DanKa Academy",
            "slidermotto": "Formação profissional para staff de eventos",
            "sliderlink": "/login/signup.php",
            "sliderbutton": "Inscreva-se"
        }]
    }
}}
<div id="herocarousel" class="at-hero carousel slide" data-bs-ride="carousel">

    {{#hasmultipleslides}}
    <div class="carousel-indicators">
        {{#slides}}
        <button type="button"
                data-bs-target="#herocarousel"
                data-bs-slide-to="{{index}}"
                {{#active}}class="active" aria-current="true"{{/active}}
                aria-label="{{#str}}jumptoslide, theme_atipico{{/str}}">
        </button>
        {{/slides}}
    </div>
    {{/hasmultipleslides}}

    <div class="carousel-inner">
        {{#slides}}
        <div class="carousel-item {{#active}}active{{/active}}">
            <img class="at-hero__img" src="{{{sliderimage}}}" alt="">
            <div class="overlay slide{{index}}"></div>
            <div class="at-hero__content">
                <div class="container">
                    <div class="at-hero__text">
                        <h1 class="at-hero__title">{{herotitle}}</h1>
                        <p class="at-hero__subtitle">{{slidermotto}}</p>
                        {{#sliderlink}}
                        <a href="{{{sliderlink}}}" class="at-hero__cta btn btn-primary btn-lg" role="button">
                            {{sliderbutton}}
                        </a>
                        {{/sliderlink}}
                    </div>
                </div>
            </div>
        </div>
        {{/slides}}
    </div>

    {{#hasmultipleslides}}
    <button class="carousel-control-prev" type="button" data-bs-target="#herocarousel" data-bs-slide="prev"
            title="{{#str}}prev, theme_atipico{{/str}}">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#herocarousel" data-bs-slide="next"
            title="{{#str}}next, theme_atipico{{/str}}">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
    {{/hasmultipleslides}}

</div>

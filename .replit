modules = ["php-8.2", "nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Theme info"

[[workflows.workflow]]
name = "Theme info"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo 'Moodle Stream Theme — edit files in /home/runner/workspace and push to GitHub.' && php -l config.php && php -l lib.php && php -l settings.php && echo 'All PHP files OK.'"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[deployment]
deploymentTarget = "vm"
run = ["/home/runner/start-moodle.sh"]
